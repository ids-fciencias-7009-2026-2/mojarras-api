{
  "info": {
    "_postman_id": "641580da-bcd7-4c2d-b924-9cdf31028ce2",
    "name": "User API - Mojarras",
    "description": "Flujo completo con JWT Bearer",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "43312256"
  },
  "item": [
    {
      "name": "Register User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let jsonData = pm.response.json();",
              "if(jsonData && jsonData.email){",
              "   pm.collectionVariables.set(\"userEmail\", jsonData.email);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user{{$timestamp}}@example.com\",\n  \"password\": \"123456\",\n  \"username\": \"user{{$timestamp}}\",\n  \"firstName\": \"Test\",\n  \"lastName\": \"User\",\n  \"zipCode\": \"12345\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/users/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users",
            "register"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let jsonData = pm.response.json();",
              "if(jsonData && jsonData.token){",
              "   pm.collectionVariables.set(\"token\", jsonData.token);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"123456\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/users/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users",
            "login"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Me",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/users/me",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users",
            "me"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Update User",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"updated{{$timestamp}}@example.com\",\n  \"password\": \"newpass123\",\n  \"username\": \"updatedUser{{$timestamp}}\",\n  \"firstName\": \"Updated\",\n  \"lastName\": \"User\",\n  \"zipCode\": \"54321\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/users",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users"
          ]
        }
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "userEmail",
      "value": ""
    }
  ]
}