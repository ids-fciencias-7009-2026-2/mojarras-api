{
  "info": {
    "name": "User API - Mojarras",
    "_postman_id": "12345678-abcd-efgh-ijkl-987654321000",
    "description": "Colección de endpoints para UserController en localhost, con flujo secuencial y captura automática de email y token",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Register User (POST /users/register)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user{{$timestamp}}@example.com\",\n  \"password\": \"123456\",\n  \"username\": \"user{{$timestamp}}\",\n  \"firstName\": \"Test\",\n  \"lastName\": \"User\",\n  \"zipCode\": \"12345\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/users/register",
          "host": ["{{baseUrl}}"],
          "path": ["users", "register"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let jsonData = pm.response.json();",
              "if(jsonData && jsonData.email){",
              "   pm.collectionVariables.set(\"userEmail\", jsonData.email);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Login (POST /users/login)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"123456\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/users/login",
          "host": ["{{baseUrl}}"],
          "path": ["users", "login"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let jsonData = pm.response.json();",
              "if(jsonData && jsonData.token){",
              "   pm.collectionVariables.set(\"token\", jsonData.token);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Retrieve User (GET /users/me)",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "{{token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/users/me",
          "host": ["{{baseUrl}}"],
          "path": ["users", "me"]
        }
      }
    },
    {
      "name": "Update User (PUT /users)",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Authorization", "value": "{{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"updated{{$timestamp}}@example.com\",\n  \"password\": \"newpass123\",\n  \"username\": \"updatedUser{{$timestamp}}\",\n  \"firstName\": \"Updated\",\n  \"lastName\": \"User\",\n  \"zipCode\": \"54321\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/users",
          "host": ["{{baseUrl}}"],
          "path": ["users"]
        }
      }
    },
    {
      "name": "Logout (POST /users/logout)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "{{token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/users/logout",
          "host": ["{{baseUrl}}"],
          "path": ["users", "logout"]
        }
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" },
    { "key": "userEmail", "value": "" }
  ]
}